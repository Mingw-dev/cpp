    "editor.suggest.showClasses": true,
    "editor.suggest.showStructs": true,
    "editor.suggest.showTypes": true,
    "files.associations": {
        "map": "cpp",
        "iostream": "cpp",
        "utility": "cpp",
        "vector": "cpp",
        "xutility": "cpp"
    }
}
